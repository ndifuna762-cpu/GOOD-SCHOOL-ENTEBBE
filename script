  const track = document.getElementById('galleryTrack');
  if (track) track.scrollBy({ left: dir * 320, behavior: 'smooth' });
}

// ─── GALLERY FILTER ───
function filterGallery(filter) {
  document.querySelectorAll('.gallery-filter-btn').forEach(b => {
    b.classList.toggle('active', b.getAttribute('data-gfilter') === filter);
  });
  document.querySelectorAll('.gallery-card').forEach(card => {
    const cat = card.getAttribute('data-gcat');
    card.classList.toggle('g-hidden', filter !== 'all' && cat !== filter);
  });
}

// ─── GALLERY LIGHTBOX ───
let currentGalleryCards = [];
let currentGalleryIndex = 0;

function openGalleryLight(card) {
  currentGalleryCards = [...document.querySelectorAll('.gallery-card:not(.g-hidden)')];
  currentGalleryIndex = currentGalleryCards.indexOf(card);
  renderLightbox();
  const lb = document.getElementById('galleryLightbox');
  if (lb) {
    lb.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }
}

function renderLightbox() {
  const card  = currentGalleryCards[currentGalleryIndex];
  const title = card.querySelector('p').textContent;
  const cat   = card.querySelector('span').textContent;
  const bg    = card.style.background;
  document.getElementById('lightboxContent').innerHTML = `
    <div style="height:400px;background:${bg};display:flex;align-items:center;justify-content:center;">
      <div style="text-align:center;color:white;">
        <p style="font-size:11px;letter-spacing:2px;text-transform:uppercase;opacity:0.7;margin-bottom:12px;">${cat}</p>
        <h3 style="font-family:'Playfair Display',serif;font-size:28px;">${title}</h3>
        <p style="opacity:0.5;font-size:12px;margin-top:8px;">Replace gradient with your real photo</p>
      </div>
    </div>
    <div style="background:#111;padding:16px 24px;display:flex;justify-content:space-between;align-items:center;">
      <span style="color:rgba(255,255,255,0.5);font-size:12px;">${currentGalleryIndex + 1} / ${currentGalleryCards.length}</span>
      <span style="color:var(--gold);font-size:12px;letter-spacing:1px;text-transform:uppercase;">${cat}</span>
    </div>`;
}

function closeGalleryLight(e) {
  if (e && e.target !== document.getElementById('galleryLightbox') && e.type === 'click') return;
  const lb = document.getElementById('galleryLightbox');
  if (lb) lb.style.display = 'none';
  document.body.style.overflow = '';
}

function prevGalleryImg() {
  currentGalleryIndex = (currentGalleryIndex - 1 + currentGalleryCards.length) % currentGalleryCards.length;
  renderLightbox();
}
function nextGalleryImg() {
  currentGalleryIndex = (currentGalleryIndex + 1) % currentGalleryCards.length;
  renderLightbox();
}

document.addEventListener('keydown', e => {
  const lb = document.getElementById('galleryLightbox');
  if (lb && lb.style.display === 'flex') {
    if (e.key === 'ArrowLeft')  prevGalleryImg();
    if (e.key === 'ArrowRight') nextGalleryImg();
    if (e.key === 'Escape')     closeGalleryLight();
  }
});

// ─── SCROLL REVEAL ───
const reveals = document.querySelectorAll('.reveal');
const observer = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) e.target.classList.add('visible');
  });
}, { threshold: 0.1 });
reveals.forEach(el => observer.observe(el));